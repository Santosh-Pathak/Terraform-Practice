# Terraform — provider and module cache (keep .terraform.lock.hcl in version control)
**/.terraform/*

# State and backups (use remote backend for team workflows)
*.tfstate
*.tfstate.*
*.backup
*.backup.*

# Crash logs
crash.log
crash.*.log

# Variable files that often hold secrets; allow documented examples
*.tfvars
*.tfvars.json
!example.tfvars
!*.example.tfvars

# Local-only overrides
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config (may contain credentials)
.terraformrc
terraform.rc

# Saved plan files
*.tfplan
*tfplan*

# Terragrunt
.terragrunt-cache/

# OS
.DS_Store
Thumbs.db

# Editors
*.swp
*.swo
*~

# Local AWS CLI v2 installer / extract (not IaC)
awscliv2.zip
/aws/
